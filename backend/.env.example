# Base de données Railway PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/alma

# Sécurité
SECRET_KEY=change-this-in-production-min-32-chars

# IA — Google Gemini Flash
GEMINI_API_KEY=your-gemini-api-key-here

# CORS — URLs autorisées (séparées par virgules)
CORS_ORIGINS=https://alma.up.railway.app,http://localhost:5173

# Environnement
ENVIRONMENT=production
